[project]
[access "refs/*"]
	owner = group Administrators
	owner = group android_tools-owners
[access "refs/for/refs/*"]
	push = group android_tools-owners
	create = group android_tools-owners
[access "refs/heads/*"]
	label-Code-Review = -1..+1 group android_tools-owners
	label-Code-Review = -1..+1 group chromium-branch-creators
	label-Commit-Ready = -1..+1 group android_tools-owners
	submit = group android_tools-owners
	submit = group chromium-branch-creators
	submit = group use-cria-project-chromium-committers-instead
	create = group android_tools-owners
	create = group chromium-branch-creators
	push = group android_tools-owners
	push = group chromium-branch-creators
[submit]
	action = cherry pick
[access "refs/branch-heads/*"]
	create = group android_tools-owners
	create = group chromium-branch-creators
	forgeAuthor = group android_tools-owners
	forgeAuthor = group chromium-branch-creators
	forgeCommitter = group android_tools-owners
	forgeCommitter = group chromium-branch-creators
	push = group android_tools-owners
	push = group chromium-branch-creators
	pushMerge = group android_tools-owners
	label-Code-Review = -1..+1 group android_tools-owners
	label-Code-Review = -1..+1 group chromium-branch-creators
	submit = group android_tools-owners
	submit = group chromium-branch-creators
[label "Code-Review"]
	function = NoBlock
	abbreviation = R
	copyMinScore = true
	copyMaxScore = true
	copyAllScoresOnTrivialRebase = true
	copyAllScoresIfNoCodeChange = true
	value = -1 not lgtm
	value = 0 no score
	value = +1 lgtm
	defaultValue = 0
	ignoreSelfApproval = true
[label "Verified"]
	function = NoBlock
	defaultValue = 0
[access "refs/heads/master"]
	exclusiveGroupPermissions = push submit
[submit-requirement "Code-Review"]
	description = Submit requirement for the 'Code-Review' label
	submittableIf = label:Code-Review=MAX,user=non_uploader -label:Code-Review=MIN
	canOverrideInChildProjects = true
[submit-requirement "Verified"]
	description = Submit requirement for the 'Verified' label
	applicableIf = is:false
	submittableIf = is:true
	canOverrideInChildProjects = true
